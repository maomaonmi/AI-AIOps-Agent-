# ==================== AI运维助手 配置文件 ====================
# 复制此文件为 .env 并填入你的配置

# ==================== LLM 模型配置 ====================
# LLM_MODE: 'local' (本地模型) 或 'cloud' (阿里云通义千问)
LLM_MODE=cloud

# 云端模型配置 (推荐 - 响应快、理解能力强)
DASHSCOPE_API_KEY=你的阿里云API_Key_在这里
DASHSCOPE_MODEL=qwen-plus

# 本地模型配置 (备用 - 需要下载模型)
QWEN_MODEL_PATH=models/qwen-1.5b

# ==================== 监控系统配置 ====================
PROMETHEUS_URL=http://localhost:9090

# ==================== 数据库配置 (可选) ====================
DATABASE_URL=postgresql://user:password@localhost:5432/aiops

# ==================== 日志系统 (可选) ====================
ELASTICSEARCH_URL=http://localhost:9200

# ==================== 告警系统 (可选) ====================
ALERTMANAGER_URL=http://localhost:9093

# ==================== SSH 配置 (可选) ====================
SSH_HOSTS_CONFIG=config/ssh_hosts.json
